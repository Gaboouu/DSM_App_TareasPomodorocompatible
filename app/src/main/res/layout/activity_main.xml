<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Título -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Pomodoro &amp; Tareas"
            android:textColor="#202124"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- Resumen -->
        <TextView
            android:id="@+id/tvSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="Pendientes: 0   •   Sesiones: 0"
            android:textColor="#5F6368"
            android:textSize="14sp" />

        <!-- ── Sección Temporizador ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="#FFFFFF"
            android:elevation="3dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Temporizador Pomodoro"
                android:textColor="#202124"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvActiveTask"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="Tarea activa: ninguna"
                android:textColor="#5F6368"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="25:00"
                android:textColor="#202124"
                android:textSize="64sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:layout_marginTop="10dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#1A73E8"
                android:progressBackgroundTint="#D0D8E4" />

            <!-- Fila 1: Iniciar / Pausar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnStart"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="▶ Iniciar" />

                <Button
                    android:id="@+id/btnPause"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="⏸ Pausar" />
            </LinearLayout>

            <!-- Fila 2: Reanudar / Reiniciar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnResume"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="▶▶ Reanudar" />

                <Button
                    android:id="@+id/btnReset"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="↺ Reiniciar" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── Sección Tareas ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Mis tareas"
            android:textColor="#202124"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Input nueva tarea -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etTask"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Escribe una tarea…"
                android:inputType="textCapSentences"
                android:maxLines="1"
                android:imeOptions="actionDone" />

            <Button
                android:id="@+id/btnAddTask"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Agregar" />
        </LinearLayout>

        <!-- Estado vacío tareas -->
        <TextView
            android:id="@+id/tvEmptyTasks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="No hay tareas todavía"
            android:textColor="#9E9E9E"
            android:visibility="visible" />

        <!-- Contenedor dinámico de tareas -->
        <LinearLayout
            android:id="@+id/tasksContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="vertical" />

        <!-- ── Sección Historial ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Historial de sesiones"
            android:textColor="#202124"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Estado vacío historial -->
        <TextView
            android:id="@+id/tvEmptyHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="No hay sesiones completadas"
            android:textColor="#9E9E9E"
            android:visibility="visible" />

        <!-- Contenedor dinámico de historial -->
        <LinearLayout
            android:id="@+id/historyContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="vertical" />

    </LinearLayout>
</ScrollView>
